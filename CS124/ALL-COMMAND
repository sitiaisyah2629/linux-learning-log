COMMAND

03 mac 2026
passwd # to change password
whoami # to see the current user
date # view date/time
date +%R # view time in 24 hour
date +%x # view date
cat argument1 argument2 # display 2 file (not by page)
less argument1 # display file (per page)
head (file/path) # display 10 line from upward
tail (file/path) # display 10 line from downward
tail -n 3 (file/path) # display 3 line from downward
wc -l -c argument1 ; argument 2 # wc word count. -l line, -c character 
TZ="Asia/Kuala_Lumpur" date # command to view kl date right now
timedatectl list -timezones # list all time zones
timedatectl list -timezones | Kuala # list all time zones start with kuala
sudo timedatectl set-timezone Asia/Kuala_Lumpur
file (file name) # to check file type

04 mac 2026
cd - # back to previous working directory  before current working directory
cd ~ # back to home directory
cd ../.. # changes the working directory up two levels from the current location
ls -al # list in the long format include hidden files
ls -R # list in the recursive way
ls thesis* # list all the file start with thesis.. (asteric is case sensitive)
cp -r ../Thesis/ . # copy everything from previous working directory, then enter in Thesis directory an copy to current directory
rm (file name) # for remove file
rm -r (path or file name) # remove everything in the target
rmdir (dir name) # only remove target directory if its empty
rm -ri (file or path) # ask confirmation before deleting
rm -rf (file or path) # forces removal without prompting confirmation

